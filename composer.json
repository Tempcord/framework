{
  "name": "tempcord/framework",
  "version": "0.6.135",
  "description": "A modern, elegant PHP framework for building Discord bots with ease",
  "type": "library",
  "require": {
    "php": "^8.5",
    "ragnarok/fenrir": "^1",
    "tempest/console": "^2",
    "tempest/core": "^2"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "CyberWolf.Studio",
      "email": "hello@cyberwolf.studio",
      "homepage": "https://cyberwolf.studio",
      "role": "Developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "keywords": [
    "discord",
    "bot",
    "framework",
    "php"
  ],
  "autoload": {
    "files": [
      "src/functions.php"
    ],
    "psr-4": {
      "Tempcord\\": "src/"
    }
  }
}
