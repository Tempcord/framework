{
  "name": "tempcord/framework",
  "version": "0.6.0",
  "description": "A modern, elegant PHP framework for building Discord bots with ease",
  "type": "library",
  "require": {
    "php": "^8.4",
    "tempest/console": "^2",
    "ragnarok/fenrir": "^1",
    "tempest/core": "^2"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "CyberWolf.Studio",
      "email": "hello@cyberwolf.studio",
      "homepage": "https://cyberwolf.studio",
      "role": "Developer"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "pestphp/pest": "^2.36",
    "phpstan/phpstan": "^1.0",
    "phpunit/phpunit": "^10.0"
  },
  "scripts": {
    "test": "pest",
    "analyse": "phpstan analyse",
    "cs-fix": "php-cs-fixer fix"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "pestphp/pest-plugin": true
    }
  },
  "keywords": [
    "discord",
    "bot",
    "framework",
    "php"
  ],
  "autoload": {
    "psr-4": {
      "Tempcord\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Playground\\": "playground/",
      "Tests\\": "tests/"
    }
  }
}
