{
    "name": "tempcord/framework",
    "version": "0.5.0",
    "description": "A modern, elegant PHP framework for building Discord bots with ease",
    "type": "library",
    "require": {
        "php": "^8.3",
        "tempest/console": "^1.6",
        "ragnarok/fenrir": "^1.0",
        "tempest/core": "^1.6"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "CyberWolf.Studio",
            "email": "hello@cyberwolf.studio",
            "homepage": "https://cyberwolf.studio",
            "role": "Developer"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.0",
        "friendsofphp/php-cs-fixer": "^3.0"
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "cs-fix": "php-cs-fixer fix"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "keywords": [
        "discord",
        "bot",
        "framework",
        "php"
    ],
    "autoload": {
        "psr-4": {
            "Tempcord\\": "src/"
        }
    }
}